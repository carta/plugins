{
  "template_key": "co_invest_gp_lp_spv_investment_management_agreement",
  "display_name": "Investment Management Agreement (UK Co-Invest GP/LP SPV)",
  "category": "uk_co_investment_spv",
  "description": "Agreement between the SPV and its investment manager, covering management fees, carried interest, and signatory details.",
  "sections": [
    {
      "key": "carta",
      "display_name": "Fund Details",
      "description": "Core fund information. The fund_name is auto-populated from the fund lookup.",
      "fields": [
        {
          "key": "fund_name",
          "type": "string",
          "required": true,
          "auto_populate_from": "fund.name",
          "prompt": "Fund name"
        }
      ]
    },
    {
      "key": "fees",
      "display_name": "Fee Structure",
      "description": "Management fee configuration for the investment manager.",
      "fields": [
        {
          "key": "management_fee_option",
          "type": "enum",
          "values": ["ANNUAL_FEE_PERCENT", "UPFRONT", "NONE"],
          "labels": {
            "ANNUAL_FEE_PERCENT": "An annual percentage of the Commitment which will be paid to the GP when the Investment is realized",
            "UPFRONT": "A percentage of the Commitment paid upfront to the GP",
            "NONE": "No"
          },
          "required": true,
          "default": "NONE",
          "prompt": "How is the management fee structured?"
        },
        {
          "key": "management_fee_percent",
          "type": "string",
          "required": false,
          "depends_on": {"field": "management_fee_option", "values": ["ANNUAL_FEE_PERCENT"]},
          "prompt": "Annual management fee percentage (e.g. 2 for 2%)"
        },
        {
          "key": "management_fee_upfront_percent",
          "type": "string",
          "required": false,
          "depends_on": {"field": "management_fee_option", "values": ["UPFRONT"]},
          "prompt": "Upfront management fee percentage (e.g. 15 for 15%)"
        },
        {
          "key": "management_fee_recipient",
          "type": "enum",
          "values": ["GP", "IM", "IA"],
          "labels": {
            "GP": "To the General Partner",
            "IM": "To the Investment Manager",
            "IA": "To the Investment Adviser"
          },
          "required": false,
          "depends_on": {"field": "management_fee_option", "values": ["ANNUAL_FEE_PERCENT", "UPFRONT"]},
          "prompt": "Who receives the management fee?"
        }
      ]
    },
    {
      "key": "manager",
      "display_name": "Investment Manager",
      "description": "The entity acting as investment manager for the SPV.",
      "signatory": true,
      "fields": [
        {
          "key": "name",
          "type": "string",
          "required": true,
          "prompt": "Investment manager entity name"
        },
        {
          "key": "address",
          "type": "string",
          "required": true,
          "prompt": "Investment manager address"
        },
        {
          "key": "signatures",
          "type": "signature_list",
          "required": true,
          "prompt": "Signatories for the investment manager"
        }
      ]
    },
    {
      "key": "partner",
      "display_name": "General Partner",
      "description": "The GP entity of the SPV.",
      "signatory": true,
      "fields": [
        {
          "key": "entity_name",
          "type": "string",
          "required": true,
          "prompt": "GP entity name"
        },
        {
          "key": "signatures",
          "type": "signature_list",
          "required": true,
          "prompt": "Signatories for the GP"
        }
      ]
    },
    {
      "key": "waterfall",
      "display_name": "Carried Interest",
      "description": "Who receives carried interest from the SPV.",
      "fields": [
        {
          "key": "payee_carried_interest_option",
          "type": "enum",
          "values": ["GP", "IM", "IA", "CIV", "NONE"],
          "labels": {
            "GP": "To the General Partner",
            "IM": "To the Investment Manager",
            "IA": "To the Investment Adviser",
            "CIV": "To one or multiple Carried Interest Partners",
            "NONE": "None"
          },
          "required": true,
          "default": "NONE",
          "prompt": "Who receives the carried interest?"
        }
      ]
    }
  ]
}
